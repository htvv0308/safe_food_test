<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <property name="severity" value="error"/>

    <!-- 文件编码 -->
    <property name="charset" value="UTF-8"/>

    <!-- 每行最大长度 -->
    <property name="tabWidth" value="4"/>

    <!-- 文件长度检查 -->
    <module name="FileLength">
        <property name="max" value="500"/>
        <property name="fileExtensions" value="java"/>
        <message key="maxLen.file"
                 value="❌ 文件超过500行。
✅ FIX: 拆分为更小的类，把辅助方法移至*Helper或infrastructure。
📖 See: docs/conventions/README.md"/>
    </module>

    <!-- 换行检查 -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        <message key="maxLen.line"
                 value="❌ 单行超过120字符。
✅ FIX: 换行缩进。
📖 See: docs/conventions/README.md"/>
    </module>

    <module name="TreeWalker">
        <!-- 方法长度检查 -->
        <module name="MethodLength">
            <property name="max" value="80"/>
            <property name="countEmpty" value="false"/>
            <message key="maxLen.method"
                     value="❌ 方法超过80行。
✅ FIX: 抽取私有方法或将职责下沉到Service/Domain。
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 禁止System.out.println -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="System\.out\.println"/>
            <property name="message"
                      value="❌ 禁止System.out.println。
✅ FIX: private static final Logger log = LoggerFactory.getLogger(X.class);
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 禁止printStackTrace -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\.printStackTrace\(\)"/>
            <property name="message"
                      value="❌ 禁止e.printStackTrace()。
✅ FIX: log.error("context message", e);
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 禁止直接new Logger -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="new Logger\("/>
            <property name="message"
                      value="❌ 禁止new Logger()。
✅ FIX: 使用@Slf4j注解或LoggerFactory.getLogger(X.class)。
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 命名检查 - 类名 -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
            <message key="name.invalid.pattern"
                     value="❌ 类名必须使用PascalCase。
✅ 例如: FoodAnalysisService
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 命名检查 - 方法名 -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalid.pattern"
                     value="❌ 方法名必须使用camelCase。
✅ 例如: analyzeFood()
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 命名检查 - 常量 -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
            <message key="name.invalid.pattern"
                     value="❌ 常量必须使用UPPER_SNAKE_CASE。
✅ 例如: MAX_RETRY_COUNT
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 空行检查 -->
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <message key="empty.line.separator"
                     value="❌ 缺少空行分隔。
✅ FIX: 在逻辑块之间添加空行。
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 左大括号位置 -->
        <module name="LeftCurly">
            <property name="maxLineLength" value="120"/>
            <message key="line.not.allow.new.line"
                     value="❌ 左大括号不能单独一行。
✅ FIX: 左大括号放在同一行末尾。
📖 See: docs/conventions/README.md"/>
        </module>

        <!-- 禁止魔法数字 -->
        <module name="MagicNumber">
            <property name="ignoreFieldDeclaration" value="true"/>
            <property name="ignoreAnnotation" value="true"/>
            <message key="magic.number"
                     value="❌ 禁止魔法数字。
✅ FIX: 提取为常量，例如: private static final int MAX_SIZE = 100;
📖 See: docs/conventions/README.md"/>
        </module>
    </module>
</module>