# Git属性配置

# 统一换行符（Windows开发时重要）
* text=auto

# 文本文件使用LF换行
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# 不转换二进制文件
*.class binary
*.jar binary
*.war binary
*.ear binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary

# 关闭行尾转换（防止_checkstyle.xml等文件被修改）
.github/workflows/* linguist-documentation

# Spring配置文件保持原样
application*.yml text eol=lf
application*.yaml text eol=lf